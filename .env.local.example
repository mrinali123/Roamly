# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL — used for share links and sitemaps.
# Local dev: http://localhost:3000
# Production (Vercel): leave unset — VERCEL_URL is injected automatically.
# Only set this in production if you have a custom domain (e.g. https://yourdomain.com).
# WARNING: Do NOT copy this localhost value into Vercel's environment variables.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Groq — console.groq.com (free tier works)
GROQ_API_KEY=gsk_your_groq_key_here

# Email — for trip collaboration invite emails
# Option A: Gmail SMTP (Google Account → Security → App Passwords)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Option B: Resend (resend.com) — requires a verified domain
RESEND_API_KEY=re_your_resend_key_here
